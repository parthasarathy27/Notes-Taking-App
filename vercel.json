{
  "version": 2,
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/server.js"
    },
    {
      "src": "/api/notes/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/users/(.*)",
      "dest": "/api/server.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
